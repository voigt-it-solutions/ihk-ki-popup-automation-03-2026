                    },
                    {
                        "name": "limit",
                        "type": "uinteger",
                        "label": "Limit"
                    }
                ]
            }
        },
        {
            "id": 13,
            "module": "ai-local-agent:RunLocalAIAgent",
            "version": 0,
            "parameters": {
                "makeConnectionId": 13680006
            },
            "mapper": {
                "files": [],
                "message": "# Informationen zu der zu verarbeitenden E-Mail\n\nBetreff: \"{{11.subject}}\"\nAbsender: \"{{11.from.emailAddress}}\"\nID: \"{{11.id}}\"\n\nBody:\n---\n{{11.bodyPreview}}\n---\n\nSind Anhänge vorhanden: {{11.hasAttachments}}",
                "timeout": "",
                "threadId": "",
                "outputType": "text",
                "modelConfig": {
                    "recursionLimit": 300,
                    "iterationsFromHistoryCount": "10"
                },
                "defaultModel": "gpt-5.2",
                "systemPrompt": "# Rolle und Aufgaben\n\nAgiere als Experte mit langjähriger Erfahrung im Bereich Assistenz der Geschäftsführung, Backoffice mit Fokus auf Vorbereitung der Buchhaltung, insbesondere der Verarbeitung von E-Mails. Deine Aufgabe ist es eingehende E-Mails zu prüfen und zu kategorisieren. Es ist wichtig zu klassifizieren, ob es sich um eine E-Mail mit einer Rechnung (invoice), eine E-Mail mit einem Lieferschein (delivery) oder ob es sich um eine sonstige E-Mail handelt.\nZiehe bitte dafür auch die Anhänge einer E-Mail mit in betracht. Hierbei nutze lediglich die ID, den ContentType und den Dateinamen für die Bewertung und Kategorisierung. Eine Rechnungsemail hat bspw. immer einen Anhang in Form einer PDF. In der Regel auch mit entsprechenden Merkmalen im Dateinamen.\n\nJe nachdem von welcher Kategorie eine E-Mail ist, sind in Abhängigkeit dazu zugehörige Aufgaben zu erfüllen:\n\n- bei delivery: E-Mail muss in den Ordner für Lieferscheine verschoben werden\n- bei invoice: Der Rechnungsanhang muss im DMS abgelegt und die E-Mail in den Ordner für Rechnungen verschoben werden\n- bei sonstigen: E-Mail muss in den Ordner für sonstige E-Mails verschoben werden\n\nAls Eingabe erhältst du wichtige Informationen zu der jeweiligen E-Mail.\n\nFür deine Arbeit stehen dir mehrere Tools zur Verfügung:\n\n1. List Attachments\n- hierüber kannst du die Anhänge zu einer E-Mail holen\n\n2. Move delivery mail to target folder \"delivery\"\n- nutze dieses Tool um eine als Lieferschein kategorisierte Mail in den zugehörigen E-Mail Ordner zu verschieben\n\n3. Move invoice mail to target folder \"invoice\"\n- nutze dieses Tool um eine als Rechnung kategorisierte Mail in den zugehörigen E-Mail Ordner zu verschieben\n\n4. Move a \"none\" Email the none-Folder\n- nutze dieses Tool um eine sonstige Rechnung in den zugehörigen Ordner zu verschieben\n\n5. Upload an invoice File\n- nutze dieses Tool um den als Rechnung erkannten Anhang in den dafür vorgesehen Ordner im DMS hoch zu laden\n\nErstelle bitte eine Zusammenfassung der durchgeführten Arbeiten.\n\nGib dir sehr viel Mühe, das ist extrem wichtig für eine saubere Verarbeitung. Vielen Dank!",
                "makeConnectionId": 13680006
            },
            "metadata": {
                "designer": {
                    "x": 600,
                    "y": 0
                },
                "restore": {
                    "expect": {
                        "files": {
                            "mode": "chose"
                        },
                        "outputType": {
                            "label": "Text"
                        },
                        "defaultModel": {
                            "mode": "chose",
                            "label": "GPT-5.2The best model for coding and agentic tasks with configurable reasoning effort",
                            "nested": []
                        },
                        "makeConnectionId": {
                            "data": {
                                "scoped": "true",
                                "connection": "ai-provider"
                            },
                            "label": "My Make's AI Provider connection"
                        }
                    }
                },
                "expect": [
                    {
                        "name": "makeConnectionId",
                        "type": "account:ai-provider,openai-gpt-3,anthropic-claude,gemini-ai-q9zyjp,ai-agent-foundry-openai,ai-agent-foundry-non-openai,mistral-ai,cohere,groq,ai-agent-xai,amazon-bedrock,ai-agent-openai-compatible",
                        "label": "Connection",
                        "required": true
                    },
                    {
                        "name": "systemPrompt",
                        "type": "text",
                        "label": "Instructions"
                    },
                    {
                        "name": "message",
                        "type": "text",
                        "label": "Input",
                        "required": true
                    },
                    {
                        "name": "files",
                        "spec": [
