                "orderby": "createdDateTime desc"
            },
            "metadata": {
                "designer": {
                    "x": 300,
                    "y": 0
                },
                "restore": {
                    "expect": {
                        "folder": {
                            "mode": "chose",
                            "path": [
                                "Organisation",
                                "2 - Projekte",
                                "IHK KI-Popup",
                                "XX - Testeingang"
                            ]
                        },
                        "orderby": {
                            "mode": "chose",
                            "label": "Created Date Time - Descending"
                        }
                    },
                    "parameters": {}
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account:azure",
                        "label": "Connection",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "name": "folder",
                        "type": "folder",
                        "label": "Mail Folder"
                    },
                    {
                        "name": "search",
                        "type": "text",
                        "label": "Search"
                    },
                    {
                        "name": "orderby",
                        "type": "select",
                        "label": "Order by",
                        "validate": {
                            "enum": [
                                "subject asc",
                                "subject desc",
                                "createdDateTime asc",
                                "createdDateTime desc",
                                "lastModifiedDateTime asc",
                                "lastModifiedDateTime desc",
                                "receivedDateTime asc",
                                "receivedDateTime desc"
                            ]
